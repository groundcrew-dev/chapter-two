---
import Layout from "@/layouts/Layout.astro"
import { fetchData, responsiveImageFragment } from "@/lib/datocms"
import { cleanHtml } from "@/lib/html"
import ArticleCard from "@/components/cards/ArticleCard.astro"
import Spacer from "@/components/blocks/Spacer.astro"
import BgMedia from "@/components/media/BgMedia.astro"
import BgImage from "@/components/media/BgImage.astro"
import { Gallery } from "@/components/blocks/Gallery.jsx"

export async function getStaticPaths() {
    const { allArticles } = await fetchData(`query { allArticles(first: 100) { slug } }`)
    return allArticles.map(a => ({ params: { slug: a.slug } }))
}

const { slug } = Astro.params
const img = `{ ${responsiveImageFragment} }`
const QUERY = `query Article($slug: String) {
    article(filter: { slug: { eq: $slug } }) {
        title
        category
        readTime
        wordsBy
        tags
        heroImage ${img}
        content {
            __typename
            ... on CenteredImageBlockRecord { caption image ${img} }
            ... on OverviewBlockRecord { heading body }
            ... on GalleryBlockRecord { slides { caption image ${img} } }
        }
    }
    allArticles(first: 5, filter: { slug: { neq: $slug } }, orderBy: date_DESC) {
        title slug category readTime listingImage ${img}
    }
    _allArticlesMeta { count }
}`

const { article, allArticles, _allArticlesMeta } = await fetchData(QUERY, { slug })
const related = allArticles.slice(0, 2)
const categoryLabel = { news: "News", announcement: "Announcement", update: "Update" }[article.category] ?? ""
const imageBlock = article.content.find(b => b.__typename === "CenteredImageBlockRecord" || b.__typename === "GalleryBlockRecord")
const bodyBlock = article.content.find(b => b.__typename === "OverviewBlockRecord")
const leadImage = imageBlock?.image ?? imageBlock?.slides?.[0]?.image
const leadCaption = imageBlock?.caption ?? imageBlock?.slides?.[0]?.caption
---

<Layout title={`${article.title} — Chapter Two`}>
    {article.heroImage ? (
        <section class="detail-hero has-meta align-center text-center" data-dark>
            <div class="hero-media" data-parallax><BgMedia image={article.heroImage} sizes="100vw" /></div>
            <div class="scrim"></div>
            <div class="pos-rel z-2 flex flex-col align-center gap-50 fade--up" data-scroll>
                <h1 class="h2 max-1300 anim-heading">{article.title}</h1>
                <div class="flex align-center gap-40"><span class="small balance">{article.readTime}</span><span class="small balance">{categoryLabel} Article</span></div>
            </div>
        </section>
    ) : (
        <section class="page page-title short">
            <h1 class="h2 anim-heading">{article.title}</h1>
            <div class="flex align-center justify-center gap-40 mt20"><span class="small balance">{article.readTime}</span><span class="small balance">{categoryLabel} Article</span></div>
        </section>
    )}

    <Spacer count={2} />

    <section class="page grid-2 gap-60 m-grid-1 m-gap-40">
        <div class="news-gallery">
            <div class="w-100 max-650 flex flex-col gap-16">
                {imageBlock?.__typename === "GalleryBlockRecord" ? <Gallery bare client:load slides={imageBlock.slides} /> : leadImage && <div class="pos-rel ratio-portrait overflow"><BgImage image={leadImage} sizes="(max-width: 768px) 90vw, 50vw" /></div>}
                {imageBlock?.__typename !== "GalleryBlockRecord" && leadCaption && <p class="small balance">{leadCaption}</p>}
            </div>
        </div>
        <div>
            <div class="w-100 max-650">
                <div class="rich-text indent fade--up balance" data-scroll set:html={cleanHtml(bodyBlock?.body)}></div>
            </div>
        </div>
    </section>

    <Spacer count={1} />

    <div class="page grid-2 gap-24 m-grid-1">
        <div class="m-hide"></div>
        <div class="grid-2 gap-24 m-grid-1 m-gap-12">
            <p class="small balance"><span>Words by</span> <span class="uppercase font-sans">{article.wordsBy}</span></p>
            {article.tags && <p class="small balance"><span>Tags</span> <span class="uppercase font-sans">{article.tags}</span></p>}
        </div>
    </div>

    <Spacer count={2} />

    {related.length > 0 && (
        <section class="page">
            <div class="flex space-between align-center">
                <h2 class="h3">Keep Exploring</h2>
                <a href="/articles" class="small nav-link flex align-center gap-8 balance">See All<span class="arrow-box dark"><span class="icon-arrow-diagonal"></span></span></a>
            </div>
            <div class="grid-2 gap-x-24 gap-y-60 mt40 m-grid-1 m-gap-40">
                {related.map(a => <ArticleCard article={a} />)}
            </div>
        </section>
    )}

    <Spacer count={2} />
</Layout>
