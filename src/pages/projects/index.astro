---
import Layout from "@/layouts/Layout.astro"
import { fetchData, responsiveImageFragment } from "@/lib/datocms"
import ProjectCard from "@/components/cards/ProjectCard.astro"
import Spacer from "@/components/blocks/Spacer.astro"

const QUERY = `query {
    allProjects(orderBy: position_ASC, first: 100) {
        title
        slug
        shortDescription
        availableResidences
        salesStatus
        category { slug }
        cardImage { ${responsiveImageFragment} }
    }
}`

const { allProjects } = await fetchData(QUERY)
const statuses = [{ label: "All", value: "all" }, { label: "Coming Soon", value: "coming_soon" }, { label: "Now Selling", value: "now_selling" }, { label: "Sold", value: "sold" }]
---

<Layout title="Projects — Chapter Two">
    <section class="page page-title">
        <h1 class="h1 anim-heading">Projects</h1>
        <div class="filter-bar small mt40 balance" data-filter data-enter>
            <span>Filter</span>
            {statuses.map((s, i) => <button class={`filter-option${i === 0 ? " is-active" : ""}`} data-status={s.value}>{s.label}</button>)}
        </div>
    </section>

    <section class="page grid-4 gap-40 m-grid-1 m-gap-40" data-grid>
        {allProjects.map(project => <ProjectCard project={project} />)}
    </section>

    <Spacer count={2} />
</Layout>
