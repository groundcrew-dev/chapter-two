---
import Layout from "@/layouts/Layout.astro"
import { fetchData, responsiveImageFragment } from "@/lib/datocms"
import SplitContent from "@/components/blocks/SplitContent.astro"
import BgImage from "@/components/media/BgImage.astro"
import Spacer from "@/components/blocks/Spacer.astro"

const QUERY = `query {
    aboutPage {
        heroHeading
        sectionTitle
        body
        featureImage { ${responsiveImageFragment} }
        featureImageCaption
        teamMembers { name role linkedinUrl image { ${responsiveImageFragment} } }
    }
}`

const { aboutPage } = await fetchData(QUERY)
const headingHtml = (aboutPage.heroHeading ?? "").replace(/\.\s+/g, ".<br>")
---

<Layout title="About — Chapter Two">
    <section class="page page-title tight">
        <h1 class="h1 anim-heading" set:html={headingHtml}></h1>
    </section>

    <Spacer count={1} />

    <section class="page">
        <div class="max-800 ma flex flex-col gap-20">
            <div class="pos-rel w-100 ratio-about overflow"><BgImage image={aboutPage.featureImage} sizes="(max-width: 768px) 90vw, 46vw" /></div>
            {aboutPage.featureImageCaption && <p class="small text-center balance">{aboutPage.featureImageCaption}</p>}
        </div>
    </section>

    <Spacer count={2} />

    <SplitContent heading={aboutPage.sectionTitle} body={aboutPage.body} spacers={2} />

    <section class="page grid-4 gap-40 m-grid-1 m-gap-40">
        {aboutPage.teamMembers.map(member => {
            const Card = member.linkedinUrl ? "a" : "div"
            const linkAttrs = member.linkedinUrl ? { href: member.linkedinUrl, target: "_blank", rel: "noreferrer" } : {}
            return (
                <Card class="card flex flex-col gap-12" data-scroll {...linkAttrs}>
                    <div class="pos-rel ratio-card overflow"><BgImage image={member.image} sizes="(max-width: 768px) 45vw, 22vw" /></div>
                    <h3 class="h3" style="margin-block: 10px">{member.name}</h3>
                    <div class="flex space-between align-center gap-16 mta">
                        <span class="small balance">{member.role}</span>
                        {member.linkedinUrl && <span class="small flex align-center gap-8 balance">LinkedIn<span class="arrow-box dark"><span class="icon-arrow-diagonal"></span></span></span>}
                    </div>
                    <div class="divider"></div>
                </Card>
            )
        })}
    </section>

    <Spacer count={2} />
</Layout>
