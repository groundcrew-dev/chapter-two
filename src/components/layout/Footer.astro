---
import { fetchData } from "@/lib/datocms"

const { siteConfig } = await fetchData(`query { siteConfig { footerTagline copyright instagramUrl } }`)
const tagline = (siteConfig?.footerTagline ?? "Considered Places. Lasting Value.").replace(/\.\s+/g, ".<br>")
const ig = siteConfig?.instagramUrl ?? "https://instagram.com"
const links = [
    { label: "Portfolio", href: "/projects" },
    { label: "About", href: "/about" },
    { label: "News", href: "/articles" },
    { label: "Contact", href: "/contact" }
]
---

<footer class="footer" data-footer>
    <div class="footer__content" data-footer-content>
        <div class="footer__top flex space-between align-center">
            <a href="/" class="footer__logo" aria-label="Chapter Two"></a>
            <nav class="footer__nav-m flex">{links.map(link => <a href={link.href} class="small">{link.label}</a>)}</nav>
            <div class="flex align-center gap-20">
                <a href={ig} target="_blank" rel="noreferrer" class="footer__ig icon-instagram" aria-label="Instagram"></a>
                <button class="toggle" aria-label="Toggle theme"><span class="toggle__knob"></span></button>
            </div>
        </div>
        <div class="footer__mid flex-1 flex flex-col align-center justify-center text-center">
            <p class="h1 small" set:html={tagline}></p>
            <a href={ig} target="_blank" rel="noreferrer" class="footer__ig-m icon-instagram" aria-label="Instagram"></a>
        </div>
        <div class="footer__bottom center-grid align-end gap-20 m-grid-1 m-gap-8">
            <span class="small op-60">{siteConfig?.copyright ?? "© 2026 Chapter Two"} All Rights Reserved.</span>
            <nav class="footer__nav-d flex gap-8 justify-self-center">{links.map((link, i) => <a href={link.href} class="small op-60 nav-link">{link.label}{i < links.length - 1 ? "," : ""}</a>)}</nav>
            <span class="small op-60 justify-self-end text-right m-text-center">Terms, Privacy, Website by Groundcrew</span>
        </div>
    </div>
</footer>
