---
import { fetchData } from "@/lib/datocms"

const { siteConfig, footer } = await fetchData(`query {
    siteConfig { footerTagline }
    footer {
        instagramUrl
        navLinks { ... on FooterLinkRecord { label url isContact } }
        copyright
        privacyLabel
        privacyUrl
        creditLabel
        creditName
        creditUrl
    }
}`)
const tagline = (siteConfig?.footerTagline ?? "Considered Places. Lasting Value.").replace(/\.\s+/g, ".<br>")
const ig = footer?.instagramUrl ?? "https://www.instagram.com/chaptertwogroup/"
const year = new Date().getFullYear()
const links = footer?.navLinks?.length
    ? footer.navLinks
    : [
          { label: "Portfolio", url: "/projects", isContact: false },
          { label: "About", url: "/about", isContact: false },
          { label: "Articles", url: "/articles", isContact: false },
          { label: "Contact", url: "#contact", isContact: true },
      ]
const copyright = footer?.copyright ?? "Chapter Two. All Rights Reserved."
const privacyLabel = footer?.privacyLabel ?? "Privacy Policy"
const privacyUrl = footer?.privacyUrl ?? "/privacy-policy"
const creditLabel = footer?.creditLabel ?? "Website by"
const creditName = footer?.creditName ?? "Groundcrew"
const creditUrl = footer?.creditUrl ?? "https://groundcrew.com.au"
---

<footer class='footer' data-footer>
    <div class='footer__content' data-footer-content>
        <div class='footer__top flex space-between align-center'>
            <a href='/' class='footer__logo' aria-label='Chapter Two'></a>
            <nav class='footer__nav-m flex'>
                {
                    links.map(link => (
                        <a href={link.url} class='small balance' {...(link.isContact ? { "data-contact-trigger": "" } : {})}>
                            {link.label}
                        </a>
                    ))
                }
            </nav>
            <div class='flex align-center gap-20'>
                <a href={ig} target='_blank' rel='noreferrer' class='footer__ig icon-instagram' aria-label='Instagram'></a>
                <button class='toggle' aria-label='Toggle theme'><span class='toggle__knob'></span></button>
            </div>
        </div>
        <div class='footer__mid flex-1 flex flex-col align-center justify-center text-center'>
            <p class='h1 small' set:html={tagline} />
            <a href={ig} target='_blank' rel='noreferrer' class='footer__ig-m icon-instagram' aria-label='Instagram'></a>
        </div>
        <div class='footer__bottom center-grid align-end gap-20 m-grid-1 m-gap-8'>
            <span class='small balance'>© {year} {copyright}</span>
            <nav class='footer__nav-d flex gap-8 justify-self-center'>
                {
                    links.map((link, i) => (
                        <a href={link.url} class='small nav-link balance' {...(link.isContact ? { "data-contact-trigger": "" } : {})}>
                            {link.label}
                            {i < links.length - 1 ? "," : ""}
                        </a>
                    ))
                }
            </nav>
            <span class='small justify-self-end text-right m-text-center balance'><a href={privacyUrl} class='hover-fade'>{privacyLabel}</a>, {creditLabel} <a href={creditUrl} target='_blank' rel='noreferrer' class='hover-fade'>{creditName}</a></span>
        </div>
    </div>
</footer>
