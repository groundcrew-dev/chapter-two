---
import BgImage from "@/components/media/BgImage.astro"

const { block } = Astro.props
---

<section class="flex flex-col gap-20">
    <div class="pos-rel w-100 max-1336 ma ratio-hero overflow"><BgImage image={block.image} sizes="(max-width: 768px) 90vw, 78vw" /></div>
    {block.caption && <p class="small op-60 text-center">{block.caption}</p>}
</section>
