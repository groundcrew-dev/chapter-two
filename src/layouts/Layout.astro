---
import "@/styles/site.scss"
import { ClientRouter } from "astro:transitions"
import Header from "@/components/layout/Header.astro"
import Footer from "@/components/layout/Footer.astro"
import ContactPopup from "@/components/layout/ContactPopup.astro"

const { title = "Chapter Two", description = "Chapter Two creates apartments, townhouses and masterplanned neighbourhoods across South East Queensland.", seo = null, projectName, projectLocation } = Astro.props
const seoTags = Array.isArray(seo) && seo.length ? seo : null
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        {seoTags ? seoTags.map((t) => {
            const Tag = t.tag
            if (Tag === "title") return <title set:html={t.content}></title>
            return <Tag {...t.attributes} />
        }) : (
            <Fragment>
                <title>{title}</title>
                <meta name="description" content={description} />
            </Fragment>
        )}
        <link rel="icon" href="/favicon.svg" />
        <script is:inline>
            try { if (localStorage.getItem("theme") === "dark") document.documentElement.classList.add("theme-dark") } catch (e) {}
        </script>
        <ClientRouter />
    </head>
    <body>
        <Header projectName={projectName} projectLocation={projectLocation} />
        <main class="page-shell" id="page-main" data-main>
            <slot />
        </main>
        <Footer />
        <ContactPopup />
        <script>
            import "@/scripts/app.js"
        </script>
    </body>
</html>
